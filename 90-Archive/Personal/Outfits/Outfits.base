# New database

filters:
  and:
    - note["base"] == link("New database.base")
properties:
  file.name:
    displayName: "1"
  Shoe:
    displayName: Shoe
  Bottom:
    displayName: Bottom
  Top:
    displayName: Top
views:
  - type: table
    name: Table View
    order:
      - file.name
      - Shoe
      - Bottom
      - Top
