# Tasks

filters:
  and:
    - note["base"] == link("Tasks.base")
properties:
  file.name:
    displayName: Name
  Assign:
    displayName: Assign
  Property:
    displayName: Property
  Status:
    displayName: Status
  Date:
    displayName: Date
views:
  - type: table
    name: Table View
    order:
      - file.name
      - Assign
      - Property
      - Status
      - Date
