# Bills

filters:
  and:
    - note["base"] == link("Bills.base")
properties:
  file.name:
    displayName: Item
  Quantity:
    displayName: Quantity
  Comments:
    displayName: Comments
  Store:
    displayName: Store
  Date:
    displayName: Date
  Price:
    displayName: Price
views:
  - type: table
    name: Table View
    order:
      - file.name
      - Quantity
      - Comments
      - Store
      - Date
      - Price
