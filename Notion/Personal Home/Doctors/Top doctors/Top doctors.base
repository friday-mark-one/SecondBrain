# Top doctors

filters:
  and:
    - note["base"] == link("Top doctors.base")
properties:
  file.name:
    displayName: Name
  No. of reviews:
    displayName: No. of reviews
  Rating:
    displayName: Rating
  Distance:
    displayName: Distance
  Cost:
    displayName: Cost
views:
  - type: table
    name: Table View
    order:
      - file.name
      - No. of reviews
      - Rating
      - Distance
      - Cost
