# New database

filters:
  and:
    - note["base"] == link("New database.base")
properties:
  file.name:
    displayName: Event
  Type:
    displayName: Type
  Reduced:
    displayName: Reduced
  Total photos:
    displayName: Total photos
  Selected:
    displayName: Selected
  Maximum:
    displayName: Maximum
views:
  - type: table
    name: Table View
    order:
      - file.name
      - Type
      - Reduced
      - Total photos
      - Selected
      - Maximum
