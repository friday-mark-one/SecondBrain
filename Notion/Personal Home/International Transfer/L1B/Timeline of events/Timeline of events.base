# Timeline of events

filters:
  and:
    - note["base"] == link("Timeline of events.base")
properties:
  file.name:
    displayName: Name
  Assign:
    displayName: Assign
  Date:
    displayName: Date
  Status:
    displayName: Status
views:
  - type: table
    name: Table View
    order:
      - file.name
      - Assign
      - Date
      - Status
